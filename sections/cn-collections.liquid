<style>
  .cn-collections {
    background: #fff;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3.75rem;
    padding-left: 3.75rem;
    padding-right: 3.75rem;
  }

  .cn-collections__heading {
    font-family: 'Roc Grotesk', sans-serif;
    font-size: 6rem;
    font-weight: 500;
    color: #000;
    text-align: center;
    line-height: 1;
    margin: 0;
  }

  .cn-collections__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: 0.625rem;
    width: 100%;
  }

  .cn-collections__item {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
  }

  .cn-collections__item:hover .cn-collections__image-inner {
    box-shadow: 0px 8px 32px 0px rgba(0, 0, 0, 0.45);
    transition: box-shadow 0.3s ease;
  }

  .cn-collections__image-wrap {
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 1.5rem;
    width: 100%;
    aspect-ratio: 1 / 1.15;
  }

  .cn-collections__image-inner {
    position: relative;
    width: 67%;
    height: 100%;
    border: 6px solid #fff;
    box-shadow: 0px 4px 20px 0px rgba(0, 0, 0, 0.33);
    overflow: hidden;
    transition: box-shadow 0.3s ease;
  }

  .cn-collections__image-inner img,
  .cn-collections__image-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cn-collections__image-placeholder {
    background: #d0d0d0;
  }

  .cn-collections__product-title {
    font-family: 'Roc Grotesk', sans-serif;
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.25;
    color: #000;
    text-transform: uppercase;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .cn-collections {
      padding-left: 2rem;
      padding-right: 2rem;
      gap: 2.5rem;
    }

    .cn-collections__heading {
      font-size: 3.5rem;
    }

    .cn-collections__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .cn-collections__product-title {
      font-size: 1.25rem;
    }
  }

  @media screen and (max-width: 749px) {
    .cn-collections {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
      gap: 2rem;
    }

    .cn-collections__heading {
      font-size: 2.25rem;
    }

    .cn-collections__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .cn-collections__product-title {
      font-size: 1rem;
    }
  }
</style>

{%- style -%}
  #cn-collections-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 989px) {
    #cn-collections-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign products_limit = section.settings.products_to_show
-%}

<section class="cn-collections" id="cn-collections-{{ section.id }}">
  <h2 class="cn-collections__heading">{{ section.settings.heading }}</h2>

  {%- if collection != blank and collection.products_count > 0 -%}
    <div class="cn-collections__grid">
      {%- for product in collection.products limit: products_limit -%}
        <a class="cn-collections__item" href="{{ product.url }}">
          <div class="cn-collections__image-wrap">
            <div class="cn-collections__image-inner">
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 720 }}"
                  srcset="
                    {{ product.featured_image | image_url: width: 360 }} 360w,
                    {{ product.featured_image | image_url: width: 540 }} 540w,
                    {{ product.featured_image | image_url: width: 720 }} 720w
                  "
                  sizes="(max-width: 749px) 45vw, (max-width: 989px) 22vw, 17vw"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                  loading="lazy"
                >
              {%- else -%}
                <div class="cn-collections__image-placeholder"></div>
              {%- endif -%}
            </div>
          </div>
          <p class="cn-collections__product-title">{{ product.title }}</p>
        </a>
      {%- endfor -%}
    </div>
  {%- elsif section.settings.collection == blank -%}
    <p style="color:#999;font-family:sans-serif;">Select a collection in the theme editor to display products here.</p>
  {%- else -%}
    <p style="color:#999;font-family:sans-serif;">No products found in this collection.</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "CN Collections",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collections"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 100
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "CN Collections"
    }
  ]
}
{% endschema %}
